
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Timetable — Absolute Arts</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700;9..40,800&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --blue: #00b4e7;
    --pink: #ec4899;
    --dark: #0a0a0f;
    --card: #111118;
    --border: rgba(255,255,255,.08);
    --muted: rgba(255,255,255,.55);
    --text: rgba(255,255,255,.92);
  }

  html, body {
    background: var(--dark);
    color: var(--text);
    font-family: 'DM Sans', system-ui, sans-serif;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  .tt-wrap {
    max-width: 1300px;
    margin: 0 auto;
    padding: 24px 16px 48px;
  }

  /* Header */
  .tt-header {
    text-align: center;
    margin-bottom: 20px;
  }
  .tt-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: #fff;
  }
  .tt-subtitle {
    font-size: clamp(.95rem, 1.8vw, 1.1rem);
    font-weight: 600;
    color: var(--blue);
    margin-top: 4px;
  }

  /* Day tabs */
  .tt-tabs {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 16px;
  }
  .tt-tab {
    padding: 10px 18px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(0,0,0,.6);
    color: var(--muted);
    font: inherit;
    font-weight: 700;
    font-size: .9rem;
    cursor: pointer;
    transition: all .2s;
  }
  .tt-tab:hover {
    color: #fff;
    border-color: rgba(255,255,255,.2);
  }
  .tt-tab.active {
    color: #fff;
    border-color: transparent;
    background: var(--blue);
  }

  /* Card container */
  .tt-card {
    border: 1px solid var(--border);
    border-radius: 18px;
    background: rgba(0,0,0,.45);
    backdrop-filter: blur(6px);
    overflow: hidden;
  }

  /* Studio column headers */
  .tt-col-heads {
    display: grid;
    gap: 8px;
    padding: 14px 14px 10px;
    border-bottom: 1px solid var(--border);
    background: rgba(0,0,0,.4);
  }
  .tt-col-head {
    padding: 10px 14px;
    border-radius: 12px;
    background: var(--blue);
    color: #fff;
    font-weight: 800;
    font-size: .9rem;
    text-align: center;
  }

  /* Rows area */
  .tt-rows {
    display: grid;
    gap: 8px;
    padding: 14px;
    align-items: start;
    max-height: 60vh;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .tt-rows::-webkit-scrollbar { width: 8px; }
  .tt-rows::-webkit-scrollbar-thumb { background: rgba(255,255,255,.15); border-radius: 999px; }

  /* Column of cells */
  .tt-column {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .tt-cell {
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: rgba(0,0,0,.6);
  }
  .tt-cell .time {
    font-weight: 800;
    font-size: .85rem;
    color: var(--blue);
    margin-bottom: 2px;
  }
  .tt-cell .name {
    color: var(--text);
    font-size: .92rem;
    font-weight: 500;
  }
  .tt-cell.private {
    opacity: .55;
    border-style: dashed;
  }
  .tt-cell.empty {
    opacity: .3;
    text-align: center;
    color: var(--muted);
    font-size: .85rem;
    padding: 14px 12px;
  }

  /* Key Dates */
  .dates-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    padding: 14px;
  }
  .date-item {
    padding: 14px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(0,0,0,.6);
  }
  .date-item .dt { font-weight: 800; color: #fff; margin-bottom: 4px; }
  .date-item .ds { color: var(--text); font-size: .92rem; }

  /* Friday special */
  .friday-banner {
    padding: 32px 20px;
    text-align: center;
    color: var(--text);
  }
  .friday-banner .fb-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 6px;
  }
  .friday-banner .fb-time {
    color: var(--blue);
    font-weight: 700;
    font-size: 1rem;
  }
  .friday-banner .fb-note {
    margin-top: 6px;
    color: var(--blue);
    font-weight: 700;
    font-size: .9rem;
  }

  /* Scroll hint */
  .scroll-hint {
    text-align: center;
    padding: 8px;
    font-size: .82rem;
    color: var(--muted);
    font-weight: 600;
    display: none;
  }
  .scroll-hint.visible { display: block; }
  .scroll-hint .arrow {
    display: inline-block;
    animation: bounce 2s ease-in-out infinite;
  }
  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-3px); }
  }

  /* Responsive */
  .cols-3 .tt-col-heads,
  .cols-3 .tt-rows { grid-template-columns: repeat(3, 1fr); }
  .cols-2 .tt-col-heads,
  .cols-2 .tt-rows { grid-template-columns: repeat(2, 1fr); }
  .cols-1 .tt-col-heads,
  .cols-1 .tt-rows { grid-template-columns: 1fr; }

  @media (max-width: 900px) {
    .cols-3 .tt-col-heads,
    .cols-3 .tt-rows,
    .cols-2 .tt-col-heads,
    .cols-2 .tt-rows { grid-template-columns: 1fr; }
    .dates-grid { grid-template-columns: 1fr; }
    .tt-rows { max-height: 65vh; }
  }

  /* Embedded mode: no padding, transparent bg */
  body.embedded {
    background: transparent;
  }
  body.embedded .tt-wrap {
    padding: 8px 0 24px;
  }
</style>
</head>
<body>
<div class="tt-wrap" id="app"></div>

<script>
// ═══════════════════════════════════════════
// TIMETABLE DATA (matches Wix CMS exactly)
// ═══════════════════════════════════════════
const TIMETABLE = {
  Monday: {
    studios: ["Studio 1 · Miss Lulu", "Studio 2 · Miss Molly", "Studio 3 · Miss Jemma"],
    classes: [
      { start: "16:00", end: "16:30", studio: 0, name: "Private Lesson Slot" },
      { start: "16:30", end: "17:15", studio: 0, name: "Pre-School / Reception Ballet & Tap" },
      { start: "17:30", end: "18:15", studio: 0, name: "Yr8+ Musical Theatre" },
      { start: "18:15", end: "19:00", studio: 0, name: "Yr8+ Drama" },
      { start: "19:15", end: "20:00", studio: 0, name: "Private Lesson Slot" },
      { start: "16:00", end: "16:30", studio: 1, name: "Preschool/Reception Acro" },
      { start: "16:30", end: "17:15", studio: 1, name: "Yr4–6 Acro (Beg/Improver)" },
      { start: "17:15", end: "17:45", studio: 1, name: "Yr1–3 Acro (Beg)" },
      { start: "17:45", end: "18:15", studio: 1, name: "Yr1–3 Acro (Improver)" },
      { start: "18:30", end: "19:15", studio: 1, name: "Yr4–6 Acro (Intermediate)" },
      { start: "19:15", end: "20:00", studio: 1, name: "Private Lesson Slot" },
      { start: "20:00", end: "21:00", studio: 1, name: "Private Lesson Slot" },
      { start: "16:00", end: "16:45", studio: 2, name: "Yr1–3 Ballet" },
      { start: "16:45", end: "17:15", studio: 2, name: "Yr1–3 Tap" },
      { start: "17:15", end: "18:00", studio: 2, name: "Yr4–6 Ballet" },
      { start: "18:00", end: "18:30", studio: 2, name: "Yr4–6 Tap Grade 2" },
      { start: "18:15", end: "18:45", studio: 2, name: "Yr4–6 Tap Grade 1" },
      { start: "20:00", end: "21:00", studio: 2, name: "Adult Choir" }
    ]
  },
  Tuesday: {
    studios: ["Studio 1", "Studio 2 · Miss Aisha", "Studio 3 · Miss Molly"],
    classes: [
      { start: "16:00", end: "16:45", studio: 0, name: "Kicks, Leaps & Turns (Yr3+)" },
      { start: "16:45", end: "17:30", studio: 0, name: "Extra Ballet (Yr3+)" },
      { start: "17:30", end: "18:15", studio: 0, name: "Extra Ballet (Yr7+)" },
      { start: "18:15", end: "19:00", studio: 0, name: "Private Lesson Slot" },
      { start: "19:15", end: "20:00", studio: 0, name: "Kicks, Leaps & Turns (Yr7+)" },
      { start: "20:00", end: "21:00", studio: 0, name: "Studio Hire" },
      { start: "16:00", end: "16:45", studio: 1, name: "Private Lesson Slot" },
      { start: "16:45", end: "17:30", studio: 1, name: "Yr7+ Acro (Improver)" },
      { start: "17:30", end: "18:15", studio: 1, name: "Strength & Stretch (Yr3+)" },
      { start: "18:15", end: "19:00", studio: 1, name: "Strength & Stretch (Yr7+)" },
      { start: "19:00", end: "20:00", studio: 1, name: "Private Lesson Slot" },
      { start: "20:00", end: "20:45", studio: 2, name: "Adv Contemporary (Yr7+)" }
    ]
  },
  Wednesday: {
    studios: ["Studio 1", "Studio 2 · Miss Molly", "Studio 3 · Miss Beth"],
    classes: [
      { start: "16:00", end: "16:45", studio: 0, name: "Reception–Yr2 Jazz & Street" },
      { start: "16:45", end: "17:30", studio: 0, name: "Beg/Inter Jazz (Yr3+)" },
      { start: "17:30", end: "18:15", studio: 0, name: "Contemporary (Yr3+)" },
      { start: "18:15", end: "19:00", studio: 0, name: "Adv Jazz (Yr3+)" },
      { start: "19:00", end: "19:45", studio: 0, name: "Beg/Inter Jazz (Yr7+)" },
      { start: "19:45", end: "20:30", studio: 0, name: "Adv Jazz (Yr7+)" },
      { start: "16:00", end: "16:45", studio: 1, name: "Beg/Inter Street (Yr3+)" },
      { start: "16:45", end: "17:30", studio: 1, name: "Adv Street (Yr3+)" },
      { start: "17:30", end: "18:15", studio: 1, name: "Beg/Inter Contemporary (Yr7+)" },
      { start: "18:15", end: "19:00", studio: 1, name: "Beg/Inter Street (Yr7+)" },
      { start: "19:00", end: "19:45", studio: 1, name: "Adv Street (Yr7+)" }
    ]
  },
  Thursday: {
    studios: ["Studio 1", "Studio 2 · Miss Aisha", "Studio 3 · Miss Jemma"],
    classes: [
      { start: "16:00", end: "16:30", studio: 0, name: "Private Lesson Slot" },
      { start: "16:30", end: "17:15", studio: 0, name: "Beg/Inter Tap (Yr7+)" },
      { start: "17:15", end: "18:00", studio: 0, name: "Adv Tap (Yr7+)" },
      { start: "18:00", end: "18:45", studio: 0, name: "Private Lesson Slot" },
      { start: "18:45", end: "19:45", studio: 0, name: "Private Lesson Slot" },
      { start: "19:45", end: "21:00", studio: 0, name: "Adv Acro (Yr7+)" },
      { start: "16:00", end: "16:45", studio: 1, name: "Private Lesson Slot" },
      { start: "16:45", end: "17:15", studio: 1, name: "Private Lesson Slot" },
      { start: "17:15", end: "18:00", studio: 1, name: "Beg/Inter Ballet (Yr7+)" },
      { start: "18:00", end: "18:45", studio: 1, name: "Pre-Pointe/Pointe (Yr7+)" },
      { start: "18:45", end: "19:45", studio: 1, name: "Adv Ballet (Yr7+)" }
    ]
  },
  Friday: {
    studios: ["Studio 1"],
    classes: [
      { start: "16:00", end: "21:00", studio: 0, name: "Dance Company Training / Rehearsals — Invite Only" }
    ]
  },
  Saturday: {
    studios: ["Studio 1 · Miss Lulu"],
    classes: [
      { start: "09:15", end: "10:00", studio: 0, name: "Preschool & Reception Theatre" },
      { start: "10:00", end: "11:00", studio: 0, name: "Yr1 & 2 Musical Theatre & Drama" },
      { start: "11:00", end: "11:45", studio: 0, name: "Yr3–5 Musical Theatre" },
      { start: "11:45", end: "12:30", studio: 0, name: "Yr3–5 Drama" },
      { start: "13:00", end: "13:45", studio: 0, name: "Yr6 & 7 Musical Theatre" },
      { start: "13:45", end: "14:30", studio: 0, name: "Yr6 & 7 Drama" }
    ]
  }
};

const KEY_DATES = [
  { title: "Spring Term", sub: "Monday 5th January – Thursday 2nd April 2026" },
  { title: "Spring Half Term", sub: "Sunday 15th – Sunday 22nd Feb 2026" },
  { title: "Summer Term", sub: "Monday 5th January – Thursday 2nd April 2026" },
  { title: "Summer Half Term", sub: "Sunday 15th – Sunday 22nd Feb 2026" },
  { title: "Autumn Term", sub: "Monday 5th January – Thursday 2nd April 2026" },
  { title: "Autumn Half Term", sub: "Sunday 15th – Sunday 22nd Feb 2026" },
  { title: "Take The Stage", sub: "Performance at The Cliffs Pavilion. Sat 27th June" },
  { title: "Note", sub: "Classes run ~36 weeks across year." }
];

// ═══════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════
function fmtTime(t) {
  const [h, m] = t.split(':');
  const hr = parseInt(h);
  if (hr < 12) return hr + ':' + m + 'am';
  if (hr === 12) return '12:' + m + 'pm';
  return (hr - 12) + ':' + m + 'pm';
}

function isPrivate(name) {
  return /private lesson/i.test(name) || /studio hire/i.test(name);
}

// ═══════════════════════════════════════════
// RENDER
// ═══════════════════════════════════════════
const DAYS = Object.keys(TIMETABLE);
const TABS = [...DAYS, 'Key Dates'];
let activeDay = 'Monday';

function render() {
  const app = document.getElementById('app');
  const day = TIMETABLE[activeDay];

  // Tabs
  let html = `
    <div class="tt-header">
      <div class="tt-title">Timetable</div>
      <div class="tt-subtitle">View our weekly class schedule</div>
    </div>
    <div class="tt-tabs" role="tablist">
      ${TABS.map(d => `
        <button class="tt-tab ${activeDay === d ? 'active' : ''}"
                role="tab" aria-selected="${activeDay === d}"
                onclick="setDay('${d}')">${d}</button>
      `).join('')}
    </div>
  `;

  // Key Dates view
  if (activeDay === 'Key Dates') {
    html += `
      <div class="tt-card">
        <div class="dates-grid">
          ${KEY_DATES.map(d => `
            <div class="date-item">
              <div class="dt">${d.title}</div>
              <div class="ds">${d.sub}</div>
            </div>
          `).join('')}
        </div>
      </div>
    `;
    app.innerHTML = html;
    return;
  }

  // Friday special layout
  if (activeDay === 'Friday') {
    html += `
      <div class="tt-card cols-1">
        <div class="tt-col-heads">
          <div class="tt-col-head">${day.studios[0]}</div>
        </div>
        <div class="friday-banner">
          <div class="fb-title">Dance Company Training / Rehearsals</div>
          <div class="fb-time">${fmtTime('16:00')} – ${fmtTime('21:00')}</div>
          <div class="fb-note">Invite Only</div>
        </div>
      </div>
    `;
    app.innerHTML = html;
    return;
  }

  // Regular day — multi-studio columns
  const numStudios = day.studios.length;
  const colClass = numStudios >= 3 ? 'cols-3' : numStudios === 2 ? 'cols-2' : 'cols-1';

  // Group classes by studio
  const byStudio = day.studios.map((_, idx) =>
    day.classes
      .filter(c => c.studio === idx)
      .sort((a, b) => a.start.localeCompare(b.start))
  );

  const totalClasses = day.classes.length;

  html += `
    <div class="tt-card ${colClass}">
      <div class="tt-col-heads">
        ${day.studios.map(s => `<div class="tt-col-head">${s}</div>`).join('')}
      </div>
      <div class="tt-rows">
        ${byStudio.map((classes, si) => `
          <div class="tt-column">
            ${classes.length ? classes.map(c => `
              <div class="tt-cell ${isPrivate(c.name) ? 'private' : ''}">
                <div class="time">${fmtTime(c.start)} – ${fmtTime(c.end)}</div>
                <div class="name">${c.name}</div>
              </div>
            `).join('') : `
              <div class="tt-cell empty">—</div>
            `}
          </div>
        `).join('')}
      </div>
      <div class="scroll-hint ${totalClasses > 8 ? 'visible' : ''}" aria-hidden="true">
        <span class="arrow">↓</span> Scroll for more times
      </div>
    </div>
  `;

  app.innerHTML = html;

  // Hide scroll hint once user scrolls
  const rows = document.querySelector('.tt-rows');
  if (rows) {
    rows.addEventListener('scroll', function handler() {
      const hint = document.querySelector('.scroll-hint');
      if (hint) hint.classList.remove('visible');
      rows.removeEventListener('scroll', handler);
    }, { once: true });
  }
}

function setDay(d) {
  activeDay = d;
  render();
}

// Detect if embedded in iframe
if (window.self !== window.top) {
  document.body.classList.add('embedded');
}

// Initial render
render();
</script>
</body>
</html>
